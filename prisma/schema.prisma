// Prisma Schema — WA Gateway Production
// Provider: PostgreSQL
// Koneksi DB dikonfigurasi di prisma.config.ts (Prisma v7)

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

enum Role {
  owner
  member
}

// Tabel user/member WhatsApp yang diotorisasi
model User {
  id         String   @id @default(uuid())
  whatsappId String   @unique // Format JID lengkap: 628xxxx@c.us atau 628xxxx@lid
  name       String
  role       Role     @default(member)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Tabel akun admin untuk Admin Panel
model AdminUser {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

// Tabel grup WhatsApp yang diotorisasi
model AllowedGroup {
  id        String   @id @default(uuid())
  groupId   String   @unique // Format JID grup lengkap: xxxxx@g.us
  name      String   // Nama/Deskripsi grup
  createdAt DateTime @default(now())
}

// Log aktivitas seluruh percakapan bot
model ActivityLog {
  id         String   @id @default(uuid())
  sender     String   // Nomor/JID pengirim
  senderName String   // Nama pengirim (pushname)
  chatId     String   // ID Chat (DM: @c.us / Group: @g.us)
  chatName   String   // Nama Chat atau nama Grup
  isGroup    Boolean
  message    String   @db.Text // Pesan masuk dari user
  reply      String   @db.Text // Balasan dari bot
  status     String   // "success" | "error"
  errorMsg   String?  @db.Text // Detail error jika status = "error"
  timestamp  DateTime @default(now())

  @@index([timestamp])
  @@index([sender])
  @@index([chatId])
}
