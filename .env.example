# Hermes API endpoint (SSE streaming)
HERMES_API_URL=http://localhost:8000/api/chat

# API key untuk autentikasi ke Hermes
HERMES_API_KEY=sk-your-hermes-api-key

# Shared secret untuk push endpoint (Hermes → Gateway)
HERMES_SECRET=random-secret-string

# Port Express server (push endpoint)
EXPRESS_PORT=0000

# Nomor owner (format: 628xxx, tanpa +). Comma separated untuk multiple.
OWNER_NUMBERS=6281xxxxxxxxx

# Nomor member (opsional). Comma separated.
MEMBER_NUMBERS=

# Group IDs yang diizinkan (comma separated). Kosongkan = semua grup boleh.
ALLOWED_GROUPS=120363xxx@g.us