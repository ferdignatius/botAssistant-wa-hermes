# ── WA Gateway Production Environment Variables ──────────────────────────────
# Salin file ini menjadi .env dan isi dengan nilai yang sebenarnya.
# JANGAN commit file .env ke git!

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT
POSTGRES_DB=wagateway
DATABASE_URL=postgresql://admin:hermesbosferdi@localhost:5489/wagateway?schema=public

# ── Hermes Agent ─────────────────────────────────────────────────────────────
HERMES_API_URL=http://hermes-agent:8689/v1/responses
HERMES_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxx
HERMES_SECRET=GANTI_DENGAN_SECRET_RANDOM_PANJANG

# ── Express Server ───────────────────────────────────────────────────────────
EXPRESS_PORT=4849

# ── Admin Panel Auth ─────────────────────────────────────────────────────────
# JWT secret: generate dengan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GANTI_DENGAN_SECRET_JWT_YANG_SANGAT_PANJANG

# ── CORS: URL domain Admin Panel (Next.js) ───────────────────────────────────
ALLOWED_ORIGIN=https://admin.domain-kamu.com

# ── Admin User Seeding ────────────────────────────────────────────────────────
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_PASSWORD=admin123
